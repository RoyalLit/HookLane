{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/deezer/:match*",
      "destination": "https://api.deezer.com/:match*"
    },
    {
      "source": "/api/itunes/:match*",
      "destination": "https://itunes.apple.com/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
